# ══════════════════════════════════════════════════════════════════
# THE SOURCER — secrets.toml
# ══════════════════════════════════════════════════════════════════
#
# SETUP:
#   Local:          Copy to .streamlit/secrets.toml and fill in values
#   Streamlit Cloud: App → Settings → Secrets → paste contents
#
# REQUIRED: Supabase (database + auth)
# OPTIONAL: Default AI key shown to all users if they don't have one
# ══════════════════════════════════════════════════════════════════

# ── Supabase (REQUIRED) ───────────────────────────────────────────
# Get from: supabase.com → Your Project → Settings → API
SUPABASE_URL      = "https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY = "your-anon-public-key-here"

# ── Default AI key (OPTIONAL) ────────────────────────────────────
# If set, users without their own key will use this.
# Leave empty ("") to require users to provide their own keys.
# Recommended: set a Groq key here for a free default experience.
ANTHROPIC_KEY_DEFAULT = ""

# ── App URL for bookmarklet (OPTIONAL) ───────────────────────
# Set this to your Streamlit Cloud app URL so the bookmarklet
# generates automatically without users having to type it.
APP_URL = "https://your-app-name.streamlit.app"

# ══════════════════════════════════════════════════════════════════
# HOW TO GET SUPABASE CREDENTIALS:
# 1. Go to supabase.com and open your project
# 2. Left sidebar → Settings → API
# 3. Copy "Project URL" → SUPABASE_URL
# 4. Copy "anon public" key → SUPABASE_ANON_KEY
# ══════════════════════════════════════════════════════════════════
