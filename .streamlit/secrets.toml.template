# .streamlit/secrets.toml
# ─────────────────────────────────────────────────────────────────
# THE SOURCER — Secrets Configuration
# ─────────────────────────────────────────────────────────────────
#
# HOW TO USE:
# 1. Copy this file to .streamlit/secrets.toml
# 2. Fill in your Supabase credentials below
# 3. NEVER commit secrets.toml to Git (it's in .gitignore)
#
# For Streamlit Cloud deployment:
# → Go to your app → Settings → Secrets → paste the contents below
# ─────────────────────────────────────────────────────────────────

# ── Supabase (Required) ───────────────────────────────────────────
# Get these from: supabase.com → Your Project → Settings → API
SUPABASE_URL = "https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY = "your-anon-key-here"

# ── Optional: Default Anthropic key (for demo/admin use) ─────────
# Users can override this with their own key in Settings
# Leave blank ("") to require users to provide their own keys
ANTHROPIC_KEY_DEFAULT = ""
